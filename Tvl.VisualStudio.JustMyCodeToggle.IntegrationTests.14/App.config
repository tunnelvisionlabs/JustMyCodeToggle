<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <!--
        VS 2022+ VSTest hosts redirect System.Collections.Immutable to 8.0.0.0.
        The legacy integration test harness depends on 1.1.36.0 during discovery,
        so redirect back to the local copy to keep VS2015-VS2019 tests visible.
      -->
      <dependentAssembly>
        <assemblyIdentity name="System.Collections.Immutable" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-8.0.0.0" newVersion="1.1.36.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>
